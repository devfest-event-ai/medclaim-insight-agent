# ── n8n Sumopod webhook URL ─────────────────────────────────────────────────
# Cara dapat: Sumopod → workflow → Webhook Trigger node → copy Production URL
# WAJIB: Klik "Publish" di kanan atas sebelum copy URL
N8N_WEBHOOK_URL=https://sumopod.app/webhook/XXXXXXXX/medclaim-extract

# ── Groq API Key (untuk Analytics Agent lokal) ───────────────────────────────
# Daftar gratis di console.groq.com — tidak butuh kartu kredit
# Model yang dipakai: qwen/qwen3-30b (extraction) + llama3-70b-8192 (analytics)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Turso Database (OPSIONAL — SQLite dipakai jika kosong) ───────────────────
# Daftar gratis di turso.tech
# Setup: npx turso auth login && npx turso db create medclaim
# Get URL: npx turso db show medclaim (column URL)
# Get token: npx turso db tokens create medclaim
TURSO_URL=libsql://medclaim-USERNAME.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSJ9.xxxx
